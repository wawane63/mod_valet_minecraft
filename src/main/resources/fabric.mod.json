{
  "schemaVersion": 1,
  "id": "valet",
  "version": "${version}",
  "name": "Valet",
  "description": "Ajoute des valets specialises, des metiers configurables et des zones de travail persistantes aux villageois.",
  "authors": [
    "Wawane"
  ],
  "icon": "assets/valet/icon.png",
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.wawane.valet.ValetMod"
    ],
    "client": [
      "com.wawane.valet.client.ValetClient"
    ]
  },
  "mixins": [
    "valet.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=${java_version}"
  }
}
